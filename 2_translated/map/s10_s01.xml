  </Speakers>
  <Strings>
    <Section>Scenario</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>女だからって手加減はしねぇぞ</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ開始
スパーダ・会話１：１</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あぁ、どうしてこんな事に……</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ開始
ルカ・会話１：３</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>え！？　あの人、さっきと様子が……</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ開始
ルカ・会話１：５</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>血気盛んな街の若者達が、祭り気分で乱入！</JapaneseText>
      <EnglishText/>
      <Notes>ステージ開始
天の声・天の声：１</Notes>
      <SpeakerId>2</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ウゼェな！　弱ェくせにカラんでくんじゃねェよ！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中１
スパーダ・会話２：１</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ごめんなさい！　ごめんなさい！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中１
ルカ・会話２：３</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どういうコンビだよ、あれは</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中１
エミルＲ・会話２：５</Notes>
      <SpeakerId>3</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>チンピラなんか倒して、早く世界樹に向かおう、エミル！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中２
マルタ・会話３：１</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>てめぇには関係ねぇだろ！　黙って俺にやられてろ！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中２
エミルＲ・会話３：３</Notes>
      <SpeakerId>3</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こっちの方が話が早くてオレは好きだぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ステージ途中２
スパーダ・会話３：５</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>キミ、このチンピラに無理やり戦わされてるんでしょ？</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦　ＶＳエミル・マルタ
マルタ・会話４：１</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>待っててね！　今チンピラを倒してキミを助けてあげるから</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦　ＶＳエミル・マルタ
マルタ・会話４：３</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕は……僕は無理やり戦わされてなんかいない</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦途中
ルカ・会話５：１</Notes>
      <SpeakerId>1</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>へっ、言うじゃねぇか、ルカ。少しは見直したぜ</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦途中
スパーダ・会話５：３</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>よくもエミルを！　もう許さないんだから！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦　先にエミル撃破
マルタ・会話６：１</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>てめぇらもう容赦しねぇ！　叩きつぶしてやる！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦　先にエミル撃破
エミルＲ・会話７：２</Notes>
      <SpeakerId>3</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>誰がチンピラだぁ！？　誰がよぉ！</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦　先にエミル撃破
スパーダ・会話８：２</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>な〜んだ！　やっぱりチンピラって口ばっかりだね</JapaneseText>
      <EnglishText/>
      <Notes>Iスパーダ編／ボス戦敗北
マルタ・会話９：１</Notes>
      <SpeakerId>4</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
  <Strings>
    <Section>Dialog</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>３０秒以内に３５Ｋ．Ｏ．を決めろ！</JapaneseText>
      <EnglishText/>
      <Notes>ミッション１／開始
ダイアログ・通達：１</Notes>
      <SpeakerId>5</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>先へ進め！</JapaneseText>
      <EnglishText/>
      <Notes>ミッション１／失敗
ダイアログ・通達：３</Notes>
      <SpeakerId>6</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
